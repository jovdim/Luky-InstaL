    {
      "type": "about",
      "id": "about_1",
      "label": "O nás",
      "order": 3,
      "fields": {
        "headline": "Prečo práve Luky InstaL?",
        "text": "Sme tím skúsených inštalatérov so sídlom v Brezovici, ktorí sa špecializujú na kompletné vodoinštalácie, kúrenie a plynové rozvody. Každý projekt pristupujeme s rovnakou dávkou precíznosti a zodpovednosti.",
        "text_secondary": "Veríme, že kvalitná práca hovorí sama za seba. Preto používame iba overené materiály, dodržiavame dohodnuté termíny a ku každému zákazníkovi pristupujeme individuálne.",
        "image": "https://images.pexels.com/photos/6419128/pexels-photo-6419128.jpeg?auto=compress&cs=tinysrgb&w=800",
        "image_secondary": "https://images.pexels.com/photos/6585598/pexels-photo-6585598.jpeg?auto=compress&cs=tinysrgb&w=400",
        "highlights": [
          { "id": "hl_1", "icon": "shield", "text": "Certifikovaní odborníci" },
          { "id": "hl_2", "icon": "clock", "text": "Dodržiavame termíny" },
          { "id": "hl_3", "icon": "check-circle", "text": "Záruka na prácu" }
        ]
      }
    },
